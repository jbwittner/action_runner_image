{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "rebaseWhen": "behind-base-branch",
  "separateMinorPatch": true,
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "dockerfile": {
    "managerFilePatterns": ["/bankwiz_server/Dockerfile/"]
  },
  "github-actions": {
    "managerFilePatterns": ["/^\\.github/workflows/.+\\.ya?ml$/"]
  },
  "packageRules": [
    {
      "description": "Group patch updates together and automerge",
      "groupName": "Patch updates",
      "matchUpdateTypes": [
        "patch",
        "pin"
      ],
      "automerge": true
    },
    {
      "description": "Automerge minor updates",
      "matchUpdateTypes": [
        "minor"
      ],
      "automerge": true
    },
    {
      "description": "Create PRs for major updates without automerge",
      "matchUpdateTypes": [
        "major"
      ],
      "dependencyDashboardApproval": false,
      "automerge": false
    }
  ],
  "lockFileMaintenance": {
    "automerge": true
  }
}
